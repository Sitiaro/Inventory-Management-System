# --- Backend environment variables ---
# Copy to .env (compose reads the root .env) or set in your hosting platform.

# SQLAlchemy connection string. Locally, docker-compose provides this.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/inventory

# Allowed front-end origins (comma separated), or * for all.
CORS_ORIGINS=*

# Products with stock at or below this value appear as "low stock".
LOW_STOCK_THRESHOLD=10
